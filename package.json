{
  "name": "autovio-mcp",
  "version": "1.0.1",
  "description": "AutoVio MCP Server - AI-powered video automation via Model Context Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "autovio-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "autovio",
    "video-automation",
    "ai",
    "claude",
    "llm"
  ],
  "author": "AutoVio Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Auto-Vio/autovio-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Auto-Vio/autovio-mcp/issues"
  },
  "homepage": "https://github.com/Auto-Vio/autovio-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
